{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "rules": {
    "no-unused-vars": "error",
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": "error",
    "no-console": "off"
  },
  "env": {
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "**/*.d.ts",
    "playground/**",
    "crate/**",
    "**/wasm/**"
  ]
}
