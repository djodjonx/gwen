{
  "name": "@gwenjs/sprite-anim",
  "version": "1.0.0",
  "description": "GWEN Sprite Animation Plugin — Animator runtime for defineUI",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./module": {
      "types": "./src/module.ts",
      "import": "./src/module.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench --watch",
    "test:watch": "vitest",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gwenjs/core": "workspace:*",
    "@gwenjs/kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@gwenjs/core": "workspace:*"
  }
}
