{
  "name": "@djodjonx/gwen-plugin-html-ui",
  "version": "0.3.0",
  "description": "GWEN HTML UI plugin — DOM renderer for defineUI",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./vite-env": {
      "types": "./dist/vite-env.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@djodjonx/gwen-kit": "workspace:*"
  },
  "devDependencies": {
    "@djodjonx/gwen-engine-core": "workspace:*",
    "@types/jsdom": "^28.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@djodjonx/gwen-engine-core": "workspace:*"
  },
  "gwen": {
    "typeReferences": [
      "@djodjonx/gwen-plugin-html-ui/vite-env"
    ],
    "serviceTypes": {
      "htmlUI": {
        "from": "@djodjonx/gwen-plugin-html-ui",
        "exportName": "HtmlUI"
      }
    }
  }
}
