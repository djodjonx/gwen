{
  "name": "@gwen/cli",
  "version": "0.1.0",
  "description": "GWEN Engine CLI — dev/build/prepare pour projets gwen.config.ts (Nuxt-like)",
  "type": "module",
  "bin": {
    "gwen": "./bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jiti": "^2.4.2"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0"
  }
}
