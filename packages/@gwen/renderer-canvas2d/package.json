{
  "name": "@gwen/renderer-canvas2d",
  "version": "0.1.0",
  "description": "GWEN Canvas2D Renderer Plugin",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@gwen/engine-core": "workspace:*",
    "@gwen/kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.0.0"
  },
  "gwen": {
    "type": "typescript",
    "serviceTypes": {
      "renderer": {
        "from": "@gwen/renderer-canvas2d",
        "exportName": "Canvas2DRendererService"
      }
    }
  }
}
