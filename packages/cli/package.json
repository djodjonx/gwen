{
  "name": "@gwenjs/cli",
  "version": "1.0.0",
  "description": "GWEN Engine CLI with Citty and schema-based config validation",
  "bin": {
    "gwen": "./bin.js"
  },
  "files": [
    "dist",
    "bin.js"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build && pnpm run test:coverage",
    "dev": "node bin.js",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@gwenjs/app": "workspace:*",
    "@gwenjs/kit": "workspace:*",
    "@gwenjs/schema": "workspace:*",
    "@gwenjs/vite": "workspace:*",
    "c12": "4.0.0-beta.3",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "jiti": "^2.4.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.0",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  }
}
