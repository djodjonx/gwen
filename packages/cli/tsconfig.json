{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "../..",
    "outDir": "./dist",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    // FIXME(type-safety): exactOptionalPropertyTypes disabled — tracked in specs/v2-fix/05-TYPE-SAFETY.md
    "exactOptionalPropertyTypes": false,
    // FIXME(type-safety): noUncheckedIndexedAccess disabled — tracked in specs/v2-fix/05-TYPE-SAFETY.md
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"],
  "extends": "../../tsconfig.base.json",
  "references": [
    {
      "path": "../schema"
    },
    {
      "path": "../core"
    },
    {
      "path": "../kit"
    },
    {
      "path": "../input"
    },
    {
      "path": "../renderer-canvas2d"
    },
    {
      "path": "../vite"
    }
  ]
}
