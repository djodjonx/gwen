{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "../..",
    "outDir": "./dist",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ],
  "extends": "../../tsconfig.base.json",
  "references": [
    {
      "path": "../schema"
    },
    {
      "path": "../core"
    },
    {
      "path": "../kit"
    },
    {
      "path": "../app"
    },
    {
      "path": "../input"
    },
    {
      "path": "../renderer-canvas2d"
    }
  ]
}