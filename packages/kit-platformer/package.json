{
  "name": "@gwenjs/kit-platformer",
  "version": "1.0.0",
  "description": "GWEN Kit — opinionated factories for 2D platformer games",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./module": {
      "types": "./src/module.ts",
      "import": "./src/module.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint src"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@gwenjs/core": "workspace:*",
    "@gwenjs/input": "workspace:*",
    "@gwenjs/kit": "workspace:*",
    "@gwenjs/physics2d": "workspace:*"
  }
}
