{
  "name": "@gwenengine/create",
  "version": "1.0.0",
  "description": "Scaffold a new GWEN Engine project — thin shim around `gwen init`",
  "bin": {
    "create-gwen-app": "./bin.js"
  },
  "files": [
    "dist",
    "bin.js",
    "src"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@gwenengine/cli": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "gwen",
    "game-engine",
    "scaffold",
    "create"
  ]
}
