{
  "name": "@gwenengine/physics3d",
  "version": "1.0.0",
  "description": "3D physics plugin foundation for GWEN \u2014 Rapier3D adapter surface",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@gwenengine/core": "workspace:*",
    "@gwenengine/kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "gwen": {
    "type": "typescript",
    "serviceTypes": {
      "physics3d": {
        "from": "@gwenengine/physics3d",
        "exportName": "Physics3DAPI"
      }
    }
  }
}
