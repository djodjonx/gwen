{
  "name": "@gwenjs/audio",
  "version": "1.0.0",
  "description": "GWEN Audio Plugin",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@gwenjs/core": "workspace:*",
    "@gwenjs/kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "gwen": {
    "serviceTypes": {
      "audio": {
        "from": "@gwenjs/audio",
        "exportName": "AudioManager"
      }
    }
  }
}
