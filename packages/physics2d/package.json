{
  "name": "@gwenjs/physics2d",
  "version": "1.0.0",
  "description": "2D physics plugin for GWEN — pure adapter for core WASM",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./core": {
      "types": "./src/core.ts",
      "import": "./src/core.ts"
    },
    "./helpers": {
      "types": "./src/helpers/index.ts",
      "import": "./src/helpers/index.ts"
    },
    "./helpers/queries": {
      "types": "./src/helpers/queries.ts",
      "import": "./src/helpers/queries.ts"
    },
    "./helpers/movement": {
      "types": "./src/helpers/movement.ts",
      "import": "./src/helpers/movement.ts"
    },
    "./helpers/contact": {
      "types": "./src/helpers/contact.ts",
      "import": "./src/helpers/contact.ts"
    },
    "./helpers/static-geometry": {
      "types": "./src/helpers/static-geometry.ts",
      "import": "./src/helpers/static-geometry.ts"
    },
    "./helpers/orchestration": {
      "types": "./src/helpers/orchestration.ts",
      "import": "./src/helpers/orchestration.ts"
    },
    "./tilemap": {
      "types": "./src/tilemap.ts",
      "import": "./src/tilemap.ts"
    },
    "./debug": {
      "types": "./src/debug.ts",
      "import": "./src/debug.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:solver": "node ./bench/bench-physics2d-solver.mjs",
    "bench:tilemap": "node ./bench/bench-physics2d-tilemap.mjs",
    "bench:bundle-size": "node ./bench/bench-physics2d-bundle-size.mjs",
    "bench:score": "node ./bench/physics-perf-score.mjs",
    "test:bench:solver": "node ./bench/check-physics-solver-bench.test.mjs",
    "test:bench:tilemap": "node ./bench/check-physics-tilemap-bench.test.mjs",
    "test:bench:tree-shaking": "node ./bench/check-physics-tree-shaking.test.mjs",
    "test:bench:score": "node ./bench/check-physics-perf-score.test.mjs",
    "test:e2e:playgrounds": "node ./bench/check-physics-playgrounds-e2e.test.mjs"
  },
  "dependencies": {
    "@gwenjs/core": "workspace:*",
    "@gwenjs/kit": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  }
}
