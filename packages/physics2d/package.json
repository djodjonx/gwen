{
  "name": "@gwenjs/physics2d",
  "version": "1.0.0",
  "description": "2D physics plugin for GWEN \u2014 pure adapter for core WASM",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./core": {
      "types": "./src/core.ts",
      "import": "./src/core.ts"
    },
    "./helpers": {
      "types": "./src/helpers/index.ts",
      "import": "./src/helpers/index.ts"
    },
    "./helpers/queries": {
      "types": "./src/helpers/queries.ts",
      "import": "./src/helpers/queries.ts"
    },
    "./helpers/movement": {
      "types": "./src/helpers/movement.ts",
      "import": "./src/helpers/movement.ts"
    },
    "./helpers/contact": {
      "types": "./src/helpers/contact.ts",
      "import": "./src/helpers/contact.ts"
    },
    "./helpers/static-geometry": {
      "types": "./src/helpers/static-geometry.ts",
      "import": "./src/helpers/static-geometry.ts"
    },
    "./helpers/orchestration": {
      "types": "./src/helpers/orchestration.ts",
      "import": "./src/helpers/orchestration.ts"
    },
    "./tilemap": {
      "types": "./src/tilemap.ts",
      "import": "./src/tilemap.ts"
    },
    "./debug": {
      "types": "./src/debug.ts",
      "import": "./src/debug.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gwenjs/core": "workspace:*",
    "@gwenjs/kit": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "gwen": {
    "type": "typescript",
    "serviceTypes": {
      "physics": {
        "from": "@gwenjs/physics2d",
        "exportName": "Physics2DAPI"
      }
    },
    "hookTypes": {
      "physics:collision": {
        "from": "@gwenjs/physics2d",
        "exportName": "Physics2DPluginHooks"
      }
    },
    "prefabExtensionTypes": {
      "physics": {
        "from": "@gwenjs/physics2d",
        "exportName": "Physics2DPrefabExtension"
      }
    }
  }
}
