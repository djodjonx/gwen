{
  "name": "@gwenengine/kit",
  "version": "1.0.0",
  "description": "GWEN plugin authoring kit \u2014 helpers for creating TS and WASM plugins",
  "keywords": [
    "game-engine",
    "gwen",
    "kit",
    "plugin",
    "wasm"
  ],
  "license": "MPL-2.0",
  "author": "Jonathan Moutier <jonathan.moutier.dev@gmail.com>",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@gwenengine/core": "workspace:*",
    "@gwenengine/schema": "workspace:*"
  },
  "devDependencies": {
    "@gwenengine/app": "workspace:*",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "gwen": {
    "type": "kit"
  }
}
