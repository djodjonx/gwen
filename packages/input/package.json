{
  "name": "@gwenjs/input",
  "version": "1.0.0",
  "description": "GWEN Input Plugin \u2014 keyboard, mouse, gamepad",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "watch": "vite build --watch",
    "lint": "oxlint src/",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@gwenjs/core": "workspace:*",
    "@gwenjs/kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "gwen": {
    "type": "typescript",
    "serviceTypes": {
      "keyboard": {
        "from": "@gwenjs/input",
        "exportName": "KeyboardInput"
      },
      "mouse": {
        "from": "@gwenjs/input",
        "exportName": "MouseInput"
      },
      "gamepad": {
        "from": "@gwenjs/input",
        "exportName": "GamepadInput"
      }
    }
  }
}
