{
  "name": "@djodjonx/gwen-plugin-physics2d",
  "version": "0.3.6",
  "description": "2D physics plugin for GWEN — Rapier2D via WASM",
  "files": [
    "dist",
    "wasm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@djodjonx/gwen-engine-core": "workspace:*",
    "@djodjonx/gwen-kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "gwen": {
    "type": "wasm-plugin",
    "wasmId": "physics2d",
    "wasmFiles": [
      "wasm/gwen_physics2d.js",
      "wasm/gwen_physics2d_bg.wasm"
    ],
    "serviceTypes": {
      "physics": {
        "from": "@djodjonx/gwen-plugin-physics2d",
        "exportName": "Physics2DAPI"
      }
    }
  }
}
