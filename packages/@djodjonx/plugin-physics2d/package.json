{
  "name": "@djodjonx/gwen-plugin-physics2d",
  "version": "1.0.0",
  "description": "2D physics plugin for GWEN — Rapier2D via WASM",
  "files": [
    "dist",
    "wasm"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.js"
    },
    "./tilemap": {
      "types": "./dist/tilemap.d.ts",
      "import": "./dist/tilemap.js"
    },
    "./debug": {
      "types": "./dist/debug.d.ts",
      "import": "./dist/debug.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@djodjonx/gwen-engine-core": "workspace:*",
    "@djodjonx/gwen-kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "gwen": {
    "type": "wasm-plugin",
    "wasmId": "physics2d",
    "wasmFiles": [
      "wasm/gwen_physics2d.js",
      "wasm/gwen_physics2d_bg.wasm"
    ],
    "serviceTypes": {
      "physics": {
        "from": "@djodjonx/gwen-plugin-physics2d",
        "exportName": "Physics2DAPI"
      }
    },
    "hookTypes": {
      "physics:collision": {
        "from": "@djodjonx/gwen-plugin-physics2d",
        "exportName": "Physics2DPluginHooks"
      }
    },
    "prefabExtensionTypes": {
      "physics": {
        "from": "@djodjonx/gwen-plugin-physics2d",
        "exportName": "Physics2DPrefabExtension"
      }
    }
  }
}
