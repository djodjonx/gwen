{
  "name": "@djodjonx/gwen-plugin-physics2d",
  "version": "1.0.0",
  "description": "2D physics plugin for GWEN — pure adapter for core WASM",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.js"
    },
    "./helpers/queries": {
      "types": "./dist/helpers-queries.d.ts",
      "import": "./dist/helpers-queries.js"
    },
    "./helpers/movement": {
      "types": "./dist/helpers-movement.d.ts",
      "import": "./dist/helpers-movement.js"
    },
    "./helpers/contact": {
      "types": "./dist/helpers-contact.d.ts",
      "import": "./dist/helpers-contact.js"
    },
    "./helpers/static-geometry": {
      "types": "./dist/helpers-static-geometry.d.ts",
      "import": "./dist/helpers-static-geometry.js"
    },
    "./helpers/orchestration": {
      "types": "./dist/helpers-orchestration.d.ts",
      "import": "./dist/helpers-orchestration.js"
    },
    "./tilemap": {
      "types": "./dist/tilemap.d.ts",
      "import": "./dist/tilemap.js"
    },
    "./debug": {
      "types": "./dist/debug.d.ts",
      "import": "./dist/debug.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@djodjonx/gwen-engine-core": "workspace:*",
    "@djodjonx/gwen-kit": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "gwen": {
    "type": "typescript",
    "serviceTypes": {
      "physics": {
        "from": "@djodjonx/gwen-plugin-physics2d",
        "exportName": "Physics2DAPI"
      }
    },
    "hookTypes": {
      "physics:collision": {
        "from": "@djodjonx/gwen-plugin-physics2d",
        "exportName": "Physics2DPluginHooks"
      }
    },
    "prefabExtensionTypes": {
      "physics": {
        "from": "@djodjonx/gwen-plugin-physics2d",
        "exportName": "Physics2DPrefabExtension"
      }
    }
  }
}
