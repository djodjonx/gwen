{
  "name": "@djodjonx/gwen-engine-core",
  "version": "1.0.0",
  "description": "GWEN Core Engine - ECS + WASM",
  "files": [
    "dist",
    "wasm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wasm/light": {
      "types": "./wasm/light/gwen_core.d.ts",
      "import": "./wasm/light/gwen_core.js"
    },
    "./wasm/physics2d": {
      "types": "./wasm/physics2d/gwen_core.d.ts",
      "import": "./wasm/physics2d/gwen_core.js"
    },
    "./wasm/physics3d": {
      "types": "./wasm/physics3d/gwen_core.d.ts",
      "import": "./wasm/physics3d/gwen_core.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "bench": "vitest bench",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@djodjonx/gwen-schema": "workspace:*",
    "hookable": "^6.0.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
