{
  "name": "@djodjonx/gwen-cli",
  "version": "0.3.5",
  "description": "GWEN Engine CLI with Citty and schema-based config validation",
  "bin": {
    "gwen": "./dist/cli/src/bin.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/cli/src/index.js",
  "types": "./dist/cli/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli/src/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/cli/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build && pnpm run test:coverage",
    "dev": "node bin.js",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@djodjonx/gwen-schema": "workspace:*",
    "c12": "4.0.0-beta.3",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "jiti": "^2.4.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
