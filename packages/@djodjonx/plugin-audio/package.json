{
  "name": "@djodjonx/gwen-plugin-audio",
  "version": "0.3.4",
  "description": "GWEN Audio Plugin",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@djodjonx/gwen-engine-core": "workspace:*",
    "@djodjonx/gwen-kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "gwen": {
    "serviceTypes": {
      "audio": {
        "from": "@djodjonx/gwen-plugin-audio",
        "exportName": "AudioManager"
      }
    }
  }
}
