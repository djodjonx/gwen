{
  "name": "@djodjonx/gwen-kit-platformer",
  "version": "1.0.0",
  "description": "GWEN Kit — opinionated factories for 2D platformer games",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./setup": {
      "import": "./dist/index.setup.js",
      "types": "./dist/index.setup.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint src"
  },
  "peerDependencies": {
    "@djodjonx/gwen-engine-core": "workspace:*",
    "@djodjonx/gwen-kit": "workspace:*",
    "@djodjonx/gwen-plugin-physics2d": "workspace:*",
    "@djodjonx/gwen-plugin-input": "workspace:*"
  },
  "devDependencies": {
    "@djodjonx/gwen-cli": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
