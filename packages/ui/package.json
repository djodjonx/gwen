{
  "name": "@gwenengine/ui",
  "version": "1.0.0",
  "description": "GWEN HTML UI plugin \u2014 DOM renderer for defineUI",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./vite-env": {
      "types": "./dist/vite-env.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gwenengine/kit": "workspace:*"
  },
  "devDependencies": {
    "@gwenengine/core": "workspace:*",
    "@types/jsdom": "^28.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@gwenengine/core": "workspace:*"
  },
  "gwen": {
    "typeReferences": [
      "@gwenengine/gwen-plugin-html-ui/vite-env"
    ],
    "serviceTypes": {
      "htmlUI": {
        "from": "@gwenengine/gwen-plugin-html-ui",
        "exportName": "HtmlUI"
      }
    }
  }
}
