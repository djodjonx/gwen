{
  "name": "gwen",
  "version": "0.1.0",
  "description": "GWEN - Composable Web Game Engine",
  "private": true,
  "type": "module",
  "license": "MPL-2.0",
  "author": "Jonathan Moutier <jonathan.moutier.dev@gmail.com>",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "install:all": "pnpm install && rustup target add wasm32-unknown-unknown",
    "build": "./scripts/build-wasm.sh && pnpm build:ts",
    "build:ts": "pnpm --filter '@gwenjs/*' build",
    "build:wasm": "./scripts/build-wasm.sh",
    "check:wasm:sizes": "./scripts/check-wasm-sizes.sh",
    "build:cargo": "./scripts/clean-cargo.sh build",
    "build:cargo:debug": "./scripts/clean-cargo.sh build-debug",
    "dev": "concurrently \"./scripts/clean-cargo.sh watch\" \"pnpm -r dev\"",
    "test": "./scripts/clean-cargo.sh test && pnpm -r test",
    "test:ts": "pnpm --filter '@gwenjs/*' test",
    "test:cargo": "./scripts/clean-cargo.sh test",
    "check:cargo": "./scripts/clean-cargo.sh check",
    "bench": "cargo bench",
    "bench:physics:tilemap": "pnpm --filter @gwenjs/physics2d build && node ./packages/physics2d/bench/bench-physics2d-tilemap.mjs",
    "test:bench:physics:tilemap": "node ./packages/physics2d/bench/check-physics-tilemap-bench.test.mjs",
    "bench:physics:solver": "node ./packages/physics2d/bench/bench-physics2d-solver.mjs",
    "test:bench:physics:solver": "node ./packages/physics2d/bench/check-physics-solver-bench.test.mjs",
    "bench:physics:bundle-size": "node ./packages/physics2d/bench/bench-physics2d-bundle-size.mjs",
    "test:bench:physics:tree-shaking": "node ./packages/physics2d/bench/check-physics-tree-shaking.test.mjs",
    "test:e2e:physics:playgrounds": "node ./packages/physics2d/bench/check-physics-playgrounds-e2e.test.mjs",
    "bench:physics:score": "node ./packages/physics2d/bench/physics-perf-score.mjs",
    "test:bench:physics:score": "node ./packages/physics2d/bench/check-physics-perf-score.test.mjs",
    "clean": "./scripts/clean-cargo.sh clean && pnpm -r clean",
    "lint": "oxlint --config oxlint.json packages/",
    "lint:fix": "oxlint --config oxlint.json --fix packages/",
    "format": "oxfmt packages/",
    "format:check": "oxfmt --check packages/",
    "typecheck": "pnpm --filter '@gwenjs/*' exec tsc --noEmit",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "verify:layout": "node ./scripts/verify-memory-layout.mjs",
    "release:dry": "pnpm changeset:version --canary",
    "release": "pnpm build && changeset publish",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "concurrently": "^8.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "defu": "^6.1.4",
    "hookable": "^6.0.1",
    "unctx": "^2.5.0"
  }
}
